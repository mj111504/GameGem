  choiceButton3: {fileID: 611493642}
  typingSpeed: 0.05
  musicSheetSprites:
  - {fileID: -306762889203820680, guid: 736158a3ded0bfd498969ca4ba601a28, type: 3}
  allDaysData:
  - dayName: 1
    dialogues:
    - sentence: "(\uC5EC\uB3D9\uC0DD \uBC29\uC758 \uBB38\uC744 \uC5F0\uB2E4. \uC624\uB298\uB3C4
        \uB098\uB97C \uBC14\uB77C\uB9CC \uBCFC \uBFD0 \uB2E4\uB978 \uBC18\uC751\uC740
        \uC5C6\uB2E4.) \uC544\uD508\uB370\uB294 \uC5C6\uC9C0? \uD544\uC694\uD55C\uAC70
        \uC788\uC73C\uBA74 \uCC3E\uC544\uC640. \uADF8\uB7FC \uAC00\uBCFC\uAC8C."
      emotion: 
      isMusicSheet: 0
      solvedWord: 
      isChoice: 0
      choice1Text: 
      choice1TargetIndex: 0
      choice2Text: 
      choice2TargetIndex: 0
      choice3Text: 
      choice3TargetIndex: 0
      isEndLine: 0
    - sentence: "[\uC624\uBE60] [\uBBF8\uC548\uD558\uB2E4]"
      emotion: 
      isMusicSheet: 0
      solvedWord: 
      isChoice: 0
      choice1Text: 
      choice1TargetIndex: 0
      choice2Text: 
      choice2TargetIndex: 0
      choice3Text: 
      choice3TargetIndex: 0
      isEndLine: 0
    - sentence: "\uD55C \uBC88\uB9CC \uB354 \uB9D0\uD574\uC904\uB798..? "
      emotion: 
      isMusicSheet: 0
      solvedWord: 
      isChoice: 0
      choice1Text: 
      choice1TargetIndex: 0
      choice2Text: 
      choice2TargetIndex: 0
      choice3Text: 
      choice3TargetIndex: 0
      isEndLine: 0
    - sentence: "(\uC18C\uB9AC\uB294 \uB4E4\uB9AC\uC9C0\uB9CC \uBB50\uB77C\uACE0
        \uD558\uB294\uC9C0 \uBAA8\uB974\uACA0\uB2E4. \uC5EC\uB3D9\uC0DD\uACFC\uC758
        \uB300\uD654\uB97C \uC6D0\uD588\uC9C0\uB9CC, \uC5EC\uB3D9\uC0DD\uC740 \uC2DC\uC120\uC744
        \uB2E4\uB978 \uACF3\uC73C\uB85C \uC62E\uAE38 \uBFD0\uC774\uB2E4.)"
      emotion: 
      isMusicSheet: 0
      solvedWord: 
      isChoice: 0
      choice1Text: 
      choice1TargetIndex: 0
      choice2Text: 
      choice2TargetIndex: 0
      choice3Text: 
      choice3TargetIndex: 0
      isEndLine: 0
    - sentence: "(\uB098\uB294 \uBB38\uC744 \uC870\uC2EC\uD788 \uB2EB\uACE0 \uBC29\uC73C\uB85C
        \uB3CC\uC544\uAC04\uB2E4.)"
      emotion: 
      isMusicSheet: 0
      solvedWord: 
      isChoice: 0
      choice1Text: 
      choice1TargetIndex: 0
      choice2Text: 
      choice2TargetIndex: 0
      choice3Text: 
      choice3TargetIndex: 0
      isEndLine: 0
  - dayName: 2
    dialogues:
    - sentence: "(\uBB38\uC744 \uC5F4\uACE0 \uB4E4\uC5B4\uAC00\uB2C8 \uBD88\uD3B8\uD55C
        \uD45C\uC815\uC758 \uC5EC\uB3D9\uC0DD\uC774 \uBCF4\uC778\uB2E4.)"
      emotion: 
      isMusicSheet: 0
      solvedWord: 
      isChoice: 0
      choice1Text: 
      choice1TargetIndex: 0
      choice2Text: 
      choice2TargetIndex: 0
      choice3Text: 
      choice3TargetIndex: 0
      isEndLine: 0
    - sentence: "[\uC624\uBE60] [\uC18C\uB9AC] [\uB54C\uBB38\uC5D0] [\uBB34\uC12D\uB2E4]"
      emotion: 
      isMusicSheet: 0
      solvedWord: 
      isChoice: 0
      choice1Text: 
      choice1TargetIndex: 0
      choice2Text: 
      choice2TargetIndex: 0
      choice3Text: 
      choice3TargetIndex: 0
      isEndLine: 0
    - sentence: 
      emotion: 
      isMusicSheet: 0
      solvedWord: 
      isChoice: 1
      choice1Text: "\uADC0\uB9C8\uAC1C\uB97C \uAC00\uC838\uB2E4 \uC900\uB2E4."
      choice1TargetIndex: 3
      choice2Text: "\uCC3D\uBB38\uC744 \uB2EB\uB294\uB2E4."
      choice2TargetIndex: 7
      choice3Text: "\uADF8\uB0E5 \uB098\uAC04\uB2E4."
      choice3TargetIndex: 9
      isEndLine: 0
    - sentence: "(\uB098\uB294 \uADC0\uB9C8\uAC1C\uB97C \uAC00\uC838\uB2E4 \uC8FC\uC5C8\uB2E4.) "
      emotion: 
      isMusicSheet: 0
      solvedWord: 
      isChoice: 1
      choice1Text: "\uADC0\uB9C8\uAC1C\uB97C \uAC00\uC838\uB2E4 \uC900\uB2E4."
      choice1TargetIndex: 0
      choice2Text: "\uCC3D\uBB38\uC744 \uB2EB\uB294\uB2E4."
      choice2TargetIndex: 0
      choice3Text: "\uADF8\uB0E5 \uB098\uAC04\uB2E4."
      choice3TargetIndex: 0
      isEndLine: 0
    - sentence: "\uC774\uAC70\uB77C\uB3C4 \uC4F8\uB798? \uC18C\uB9AC\uAC00 \uBA48\uCD9C
        \uB54C \uAE4C\uC9C0\uB9CC \uB07C\uACE0\uC788\uC5B4"
      emotion: 
      isMusicSheet: 0
      solvedWord: 
      isChoice: 1
      choice1Text: "\uADC0\uB9C8\uAC1C\uB97C \uAC00\uC838\uB2E4 \uC900\uB2E4."
      choice1TargetIndex: 0
      choice2Text: "\uCC3D\uBB38\uC744 \uB2EB\uB294\uB2E4."
      choice2TargetIndex: 0
      choice3Text: "\uADF8\uB0E5 \uB098\uAC04\uB2E4."
      choice3TargetIndex: 0
      isEndLine: 0
    - sentence: "(\uC5EC\uB3D9\uC0DD\uC740 \uC7A0\uC2DC \uBA48\uCE6B\uD558\uB354\uB2C8
        \uC870\uC2EC\uC2A4\uB7FD\uAC8C \uAC00\uC838\uAC00 \uB080\uB2E4.)\r\n"
      emotion: 
      isMusicSheet: 0
      solvedWord: 
      isChoice: 1
      choice1Text: "\uADC0\uB9C8\uAC1C\uB97C \uAC00\uC838\uB2E4 \uC900\uB2E4."
      choice1TargetIndex: 0
      choice2Text: "\uCC3D\uBB38\uC744 \uB2EB\uB294\uB2E4."
      choice2TargetIndex: 0
      choice3Text: "\uADF8\uB0E5 \uB098\uAC04\uB2E4."
      choice3TargetIndex: 0
      isEndLine: 0
    - sentence: "(\uC5EC\uB3D9\uC0DD\uC758 \uD45C\uC815\uC774 \uD55C\uACB0 \uB098\uC544\uC9C4
        \uAC83 \uAC19\uB2E4.)\r\n"
      emotion: 
      isMusicSheet: 0
      solvedWord: 
      isChoice: 1
      choice1Text: "\uADC0\uB9C8\uAC1C\uB97C \uAC00\uC838\uB2E4 \uC900\uB2E4."
      choice1TargetIndex: 0
      choice2Text: "\uCC3D\uBB38\uC744 \uB2EB\uB294\uB2E4."
      choice2TargetIndex: 0
      choice3Text: "\uADF8\uB0E5 \uB098\uAC04\uB2E4."
      choice3TargetIndex: 0
      isEndLine: 1
    - sentence: "(\uB098\uB294 \uC18C\uB9AC\uAC00 \uC0D0\uB9CC\uD55C \uCC3D\uBB38\uC744
        \uBAA8\uB450 \uB2EB\uC558\uB2E4. \uC544\uC9C1 \uC18C\uB9AC\uAC00 \uC0C8\uAE34\uD558\uC9C0\uB9CC
        \uC870\uAE08 \uB098\uC544\uC9C4 \uB4EF \uD558\uB2E4.)"
      emotion: 
      isMusicSheet: 0
      solvedWord: 
      isChoice: 1
      choice1Text: "\uADC0\uB9C8\uAC1C\uB97C \uAC00\uC838\uB2E4 \uC900\uB2E4."
      choice1TargetIndex: 0
