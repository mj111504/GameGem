    - target: {fileID: 1152659538749765708, guid: 0d93bcb485b26bb4fa2064b10d339490, type: 3}
      propertyPath: firstDialogue
      value: "( \uC608\uC804\uC5D0 \uCC0D\uC5C8\uB358 \uAC00\uC871\uC0AC\uC9C4\uC774\uB2E4.
        \uC774\uC820 \uBCFC \uC218 \uC5C6\uB294 \uBD80\uBAA8\uB2D8\uB3C4, \uBC1D\uC558\uB358
        \uC5EC\uB3D9\uC0DD\uB3C4 \uC0AC\uC9C4\uC73C\uB85C\uB77C\uB3C4 \uBCFC \uC218
        \uC788\uC73C\uB2C8 \uB2E4\uD589\uC774\uB77C\uACE0 \uD574\uC57C\uD558\uB098,
        \uB9C8\uC74C \uD55C\uCF20\uC774 \uC544\uB9AC\uB2E4.)"
