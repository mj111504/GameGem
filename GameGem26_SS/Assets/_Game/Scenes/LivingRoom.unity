    - target: {fileID: 1152659538749765708, guid: 0d93bcb485b26bb4fa2064b10d339490, type: 3}
      propertyPath: secondDialogue
      value: "( \uC608\uC804\uC758 \uC5EC\uB3D9\uC0DD\uC740 \uD56D\uC0C1 \uBA38\uB9AC\uB97C
        \uD56D\uC0C1 \uB9AC\uBCF8 \uBAA8\uC591\uC758 \uB9E4\uB4ED\uC73C\uB85C \uBB36\uACE0
        \uB2E4\uB154\uC9C0. \uBB3C\uB860 \uBD80\uBAA8\uB2D8\uC774 \uD56D\uC0C1 \uD574\uC8FC\uC168\uACE0
        \uAC00\uB054\uC529 \uBD80\uBAA8\uB2D8\uC774 \uBABB \uD574\uC8FC\uC2DC\uBA74
        \uB0B4\uAC00 \uD574\uC8FC\uACE4 \uD588\uC5C8\uB2E4.)\r\n"
